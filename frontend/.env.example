# =============================================================
# SatQuest frontend env — sample file (safe to commit).
# Copy to `.env` and fill in real values; `.env` is gitignored.
# Only vars prefixed with VITE_ are exposed to the browser.
# =============================================================

# Base URL of the NestJS backend.
# - Leave blank ("") to use the Vite dev proxy (forwards /api/* to localhost:3000).
# - In production set this to the deployed API origin, e.g.
#   VITE_API_URL=https://api.satquest.app
VITE_API_URL=http://localhost:3000

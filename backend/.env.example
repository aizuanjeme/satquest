# Port the NestJS server listens on
PORT=3000

# =============================================================
# Postgres (TypeORM)
# Either set DATABASE_URL OR the discrete DB_* variables below.
# =============================================================
DATABASE_URL=postgres://user:password@your-db-host:5432/satquest
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=satquest
# DB_PASSWORD=satquest
# DB_NAME=satquest

# Use TLS to connect (true for managed providers like Supabase / Neon / RDS)
DATABASE_SSL=false

# Auto-sync schema from entities. Convenient in dev, NEVER in production —
# generate proper migrations instead.
DB_SYNCHRONIZE=true

# Log every SQL statement.
DB_LOGGING=false

# =============================================================
# Breez SDK — Spark (Lightning)
# Request an API key here: https://breez.technology/request-api-key/
# Docs: https://sdk-doc-spark.breez.technology/
# =============================================================

# Required. The service refuses Lightning requests with 503 if unset.
BREEZ_API_KEY=

# Bitcoin network. Use "regtest" while developing, switch to "mainnet" for production.
BREEZ_NETWORK=mainnet

# Where the SDK persists per-wallet state. Subdirs are created per username.
BREEZ_STORAGE_DIR=/data/breez

# BIP-39 mnemonic for the SERVER reward wallet.
# This wallet is the source of funds that pays out player rewards on /claim.
# Generate once with: node -e "const b=require('bip39');console.log(b.generateMnemonic())"
# KEEP SECRET — never commit the real value.
BREEZ_SERVER_MNEMONIC=

# Public LNURL-pay domain used to mint each player's Lightning Address.
# Breez's hosted service is `breez.tips` (free, included with the SDK).
# Each player gets `<handle>@breez.tips` automatically on first wallet open.
BREEZ_LNURL_DOMAIN=breez.tips

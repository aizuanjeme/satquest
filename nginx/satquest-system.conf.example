# System nginx config for SatQuest — copy to /etc/nginx/sites-available/satquest
# then: sudo ln -s /etc/nginx/sites-available/satquest /etc/nginx/sites-enabled/
# then: sudo nginx -t && sudo systemctl reload nginx
#
# Replace YOUR_DOMAIN with your actual domain (e.g. satquest.com or satquest.yourdomain.com)

server {
    listen 80;
    server_name YOUR_DOMAIN;

    location / {
        proxy_pass         http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
